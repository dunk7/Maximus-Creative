# Auto mode (default): picks smartest available model + falls back if API fails
LLM_AUTO=true
LLM_PROVIDER=google
LLM_API_KEY=
# Grok / xAI backup — get key at https://console.x.ai/
GROK_API_KEY=
# Also accepts XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Manual override only when LLM_AUTO=false
LLM_MODEL=

DATABASE_PATH=./data/agent.db
AGENT_WALLET_PATH=./wallet/agent.json
TICK_INTERVAL_MS=900000
WAKE_PORT=4747
WAKE_SECRET=create
FAMILY_PASSWORD=family
FRIEND_PASSWORD=friend
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WEB3_STORAGE_TOKEN=
MAXIMUS_STATUS_URL=http://127.0.0.1:4747/status
